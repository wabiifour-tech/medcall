# Database - Get these from your Vercel database provider (Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host:5432/database?pgbouncer=true&connect_timeout=15"
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/database"

# NextAuth.js Secret - Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="https://your-app.vercel.app"

# WebRTC Configuration (optional - for production video calls)
STUN_SERVER="stun:stun.l.google.com:19302"
TURN_SERVER="turn:your-turn-server.com:3478"
TURN_USERNAME="your-username"
TURN_PASSWORD="your-password"
